{# Shared external-LB vLLM launch helper, included once per template and called
   from every per-rank launch site (multi-node and disaggregated).
   One vLLM API server per DP rank, pinned to its GPU slice. #}
# rank_log <node_rank> <k> — DP rank 0 logs to the node-level file (node_<rank>.log,
# the target of the top-level inference.log symlink) so it captures real server output;
# ranks 1+ get their own node_<rank>_rank<k>.log.
rank_log() {
    if [ "$2" -eq 0 ]; then
        echo "$OUTPUT_DIR/logs/inference/node_$1.log"
    else
        echo "$OUTPUT_DIR/logs/inference/node_$1_rank$2.log"
    fi
}

# launch_inference_rank <port> <cuda_visible_devices> <dp> <rpc_port> <vllm_extra_json|""> <nixl_side_channel_port|""> <log_file>
launch_inference_rank() {
    local port="$1" gpus="$2" dp="$3" rpc="$4" extra="$5" nixl="$6" log="$7"
    local -a cmd=(uv run --no-sync inference @ "$CONFIG_PATH"
        --server.host 0.0.0.0 --server.port "$port"
        --parallel.dp "$dp" --data-parallel-size-local 1 --api-server-count 1)
    [ -n "$rpc" ] && cmd+=(--data-parallel-rpc-port "$rpc")
    [ -n "$extra" ] && cmd+=(--vllm-extra "$extra")
    # Opt-in Nsight Systems profiling of the head DP-rank server (PRIME_RL_NSYS=1).
    # Time-window via PRIME_RL_NSYS_DELAY/DURATION (seconds); no-op when unset.
    # With a duration, keep the target alive and wait for normal process exit;
    # otherwise nsys exits after capture and the top-level wait -n tears down.
    local -a nsys_prefix=()
    if [ "${PRIME_RL_NSYS:-0}" = "1" ] && [ "$port" = "$BACKEND_PORT" ]; then
        mkdir -p "$OUTPUT_DIR/nsys"
        nsys_prefix=("${PRIME_RL_NSYS_BIN:-nsys}" profile
            --trace=cuda,nvtx,osrt,cublas,cudnn --cuda-memory-usage=true
            --sample=process-tree --cpuctxsw=process-tree
            --gpu-metrics-devices=cuda-visible --gpu-metrics-set=gh100
            --force-overwrite=true --stats=false --kill=none
            ${PRIME_RL_NSYS_DURATION:+--stop-on-exit=false}
            ${PRIME_RL_NSYS_DELAY:+--delay=$PRIME_RL_NSYS_DELAY}
            ${PRIME_RL_NSYS_DURATION:+--duration=$PRIME_RL_NSYS_DURATION}
            -o "$OUTPUT_DIR/nsys/infer_node${INFER_NODE_RANK}_dp0")
    fi
    if [ -n "$nixl" ]; then
        CUDA_VISIBLE_DEVICES="$gpus" PRIME_RL_JIT_MONITOR_LOG_DIR="$OUTPUT_DIR/logs/inference" PRIME_RL_FINITE_TOPK_SAMPLED_LOGPROB_STATS_LOG_DIR="$OUTPUT_DIR/logs/inference" VLLM_NIXL_SIDE_CHANNEL_PORT="$nixl" "${nsys_prefix[@]}" "${cmd[@]}" 2>&1 | tee -a "$log" &
    else
        CUDA_VISIBLE_DEVICES="$gpus" PRIME_RL_JIT_MONITOR_LOG_DIR="$OUTPUT_DIR/logs/inference" PRIME_RL_FINITE_TOPK_SAMPLED_LOGPROB_STATS_LOG_DIR="$OUTPUT_DIR/logs/inference" "${nsys_prefix[@]}" "${cmd[@]}" 2>&1 | tee -a "$log" &
    fi
}
