#!/bin/bash

#SBATCH --job-name={{ job_name }}
#SBATCH --nodes={{ num_nodes }}
#SBATCH --ntasks-per-node=1
#SBATCH --gres=gpu:{{ gpus_per_node }}
#SBATCH --exclusive
#SBATCH --partition={{ partition }}
{%- if account %}
#SBATCH --account={{ account }}
{%- endif %}
{%- if time %}
#SBATCH --time={{ time }}
{%- endif %}
{%- if nodelist %}
#SBATCH --nodelist={{ nodelist }}
{%- endif %}
{%- if exclude %}
#SBATCH --exclude={{ exclude }}
{%- endif %}
#SBATCH --output={{ output_dir }}/job_%j.log
#SBATCH --error={{ output_dir }}/job_%j.log

# Isambard-AI Phase 2 multi-node SFT template.
#
# Fork of isambard_single_node_sft.sbatch.j2:
#   - assumes venv bootstrapped (no `uv sync`, preserves aarch64 flash-attn wheel)
#   - loads brics/nccl + brics/aws-ofi-nccl (auto-sets NCCL_NET="AWS Libfabric",
#     NCCL_SOCKET_IFNAME="hsn", NCCL_NET_GDR_LEVEL="PHB" for Slingshot 11)
#   - launches via srun + torchrun rdzv; no ibv_devinfo (Slingshot is libfabric,
#     not IB).
#   - per-node log under {{ output_dir }}/logs/trainer/node_<rank>.log

set -euo pipefail

export NUM_NODES={{ num_nodes }}
export GPUS_PER_NODE={{ gpus_per_node }}
export PROJECT_DIR={{ project_dir }}
export CONFIG_PATH={{ config_path }}
export OUTPUT_DIR={{ output_dir }}
mkdir -p "$OUTPUT_DIR/logs/trainer"
ln -sfn trainer/node_0.log "$OUTPUT_DIR/logs/trainer.log"

export CUDA_DEVICE_ORDER=PCI_BUS_ID
export PYTHONUNBUFFERED=1
export OMP_NUM_THREADS=1

HOSTNAMES=( $( scontrol show hostnames "$SLURM_JOB_NODELIST" ) )
export MASTER_ADDR="${HOSTNAMES[0]}"
export MASTER_PORT=29500
echo "HOSTNAMES=${HOSTNAMES[@]}"
echo "MASTER_ADDR=${MASTER_ADDR}:${MASTER_PORT}"

# Slingshot NCCL modules auto-set the FI_CXI_*/NCCL_* defaults tuned for
# GH200 + Cassini. NCCL_ALGO left unset: Ring is optimal only on NVLink,
# not across Slingshot at larger world sizes — let NCCL pick.
module load brics/nccl 2>/dev/null || true
module load brics/aws-ofi-nccl 2>/dev/null || true
unset NCCL_ALGO

{% if pre_run_command %}
# Per-config pre-run command
{{ pre_run_command }}
{% endif %}

srun \
    --cpu-bind=none \
    --gpu-bind=none \
    --gpus-per-task={{ gpus_per_node }} \
    --kill-on-bad-exit=1 \
    bash -c '
    # Unset any SLURM-populated CUDA_VISIBLE_DEVICES that might pin to a single GPU;
    # torchrun needs to see all 4 GH200s so it can spawn nproc-per-node workers.
    unset CUDA_VISIBLE_DEVICES
    set -euo pipefail
    cd "$PROJECT_DIR"
    [ -f .env ] && source .env
    source .venv/bin/activate

    # Re-load modules inside srun (each node inherits login-node env, but modules
    # need to be present in PATH/LD_LIBRARY_PATH on every compute node).
    module load brics/nccl 2>/dev/null || true
    module load brics/aws-ofi-nccl 2>/dev/null || true

    ulimit -n 65536
    export GIT_LFS_SKIP_SMUDGE=1
    # HF cache misses are allowed to pull from the hub (compute nodes have HTTPS).
    export PYTORCH_CUDA_ALLOC_CONF="expandable_segments:True"

    TRAIN_NODE_RANK=$SLURM_PROCID
    NODE_LOG=$OUTPUT_DIR/logs/trainer/node_${TRAIN_NODE_RANK}.log

    if [ "$TRAIN_NODE_RANK" = "0" ]; then
        python - <<PY
import sys, torch, flash_attn  # noqa: F401
assert torch.cuda.is_available(), "CUDA not available"
print(f"[rank0] venv OK: torch={torch.__version__} cuda={torch.version.cuda} gpus={torch.cuda.device_count()}", file=sys.stderr)
PY
    fi

    echo "[node ${TRAIN_NODE_RANK}] hostnames=${HOSTNAMES[*]} master=${MASTER_ADDR}:${MASTER_PORT}" | tee "$NODE_LOG"

    uv run --no-sync torchrun \
        --nnodes=$NUM_NODES \
        --nproc-per-node=$GPUS_PER_NODE \
        --node-rank=$TRAIN_NODE_RANK \
        --rdzv-endpoint=$MASTER_ADDR:$MASTER_PORT \
        --rdzv-id=job_$SLURM_JOB_ID \
        --log-dir=$OUTPUT_DIR/logs/trainer/torchrun \
        --tee=3 \
        --redirects=3 \
        --local-ranks-filter={{ ranks_filter }} \
        -m prime_rl.trainer.sft.train \
        @ $CONFIG_PATH \
        2>&1 | tee -a "$NODE_LOG"
'
